# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Data (user-specific, generated at runtime)
data/
output/

# Knowledge base — large binaries and user-specific data
knowledge_base/books/*.pdf
knowledge_base/research/*.pdf
knowledge_base/previous_threat_models/*
!knowledge_base/previous_threat_models/.gitkeep
knowledge_base/ai_threats/*.pdf
knowledge_base/ai_threats/*.json
knowledge_base/risks_mitigations/*.csv
knowledge_base/risks_mitigations/*.json

# RAG data directory (user-specific CSVs and threat models)
rag/*
!rag/.gitkeep

# IDE / Editor
.vscode/
.idea/
.cursor/

# OS
Thumbs.db
.DS_Store

# Logs
logs/
*.log

# Secrets / local config
config.json
.env

# Node / Electron
node_modules/
out/
.webpack/
*.dmg
*.exe
*.deb
*.rpm
